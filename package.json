{
  "name": "@danmestas/orch-executor-cf-worker",
  "version": "0.1.0",
  "description": "orch executor backend: provisions Cloudflare Worker open-agent bridges from a SpawnSpec YAML on stdin and emits a WorkerHandle YAML on stdout. Implements orch proposal 0002 / executor-protocol.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danmestas/orch-executor-cf-worker.git"
  },
  "bugs": "https://github.com/danmestas/orch-executor-cf-worker/issues",
  "homepage": "https://github.com/danmestas/orch-executor-cf-worker#readme",
  "bin": {
    "orch-executor-cf-worker": "bin/orch-executor-cf-worker"
  },
  "files": [
    "bin/",
    "dist/",
    "schemas/",
    "src/worker/",
    "wrangler.toml",
    "README.md",
    "MIGRATION.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "version-probe": "node dist/cli.js --version",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@types/node": "20.16.10",
    "typescript": "5.6.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
