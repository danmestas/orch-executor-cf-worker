#!/usr/bin/env node
// orch-executor-cf-worker — npm-installed binary shim.
//
// Resolves the compiled CLI from this package's dist/ and re-execs
// into it. Kept as a tiny shim (rather than `node ./dist/cli.js` in
// package.json's "bin") so the file is directly invokable from PATH
// even when discovered outside of an npm-managed environment (orch's
// hybrid discovery: env override > PATH > in-tree fallback).

import { spawn } from "node:child_process";
import { fileURLToPath } from "node:url";
import { dirname, resolve } from "node:path";
import { existsSync } from "node:fs";

const here = dirname(fileURLToPath(import.meta.url));
const cliPath = resolve(here, "..", "dist", "cli.js");

if (!existsSync(cliPath)) {
  process.stderr.write(
    `orch-executor-cf-worker: built CLI not found at ${cliPath}\n` +
    `Run "npm run build" (or "npm install" from the repo) to compile src/ → dist/.\n`,
  );
  process.exit(70);
}

const child = spawn(process.execPath, [cliPath, ...process.argv.slice(2)], {
  stdio: "inherit",
});
child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
    return;
  }
  process.exit(code ?? 1);
});
child.on("error", (err) => {
  process.stderr.write(`orch-executor-cf-worker: failed to launch CLI: ${err.message}\n`);
  process.exit(70);
});
